# ════════════════════════════════════════════════════════════════════
#  ZOLA ASHÉ — Backend autonome — GABARIT PRODUCTION
#  Sur le VPS :  cp .env.prod.example .env  puis remplacer toutes les
#  valeurs « CHANGEME ». Ne JAMAIS committer .env.
# ════════════════════════════════════════════════════════════════════

# === Django ===
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_ENV=prod
DEBUG=False
# Clé secrète Django (50+ caractères, générer avec :
#   python -c "import secrets; print(secrets.token_urlsafe(64))")
DJANGO_SECRET_KEY=CHANGEME
# Domaines acceptés par Django. backend est interne (healthcheck).
DJANGO_ALLOWED_HOSTS=api.zola-ashe.com,backend

# === PostgreSQL ===
POSTGRES_USER=zola
# Mot de passe fort (32+ caractères) :
#   openssl rand -base64 32
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=zola
# L'application passe par PgBouncer (transaction pooling).
DATABASE_URL=postgres://zola:CHANGEME@pgbouncer:5432/zola
USE_PGBOUNCER=True
# Réplica en lecture (laisser vide tant qu'il n'existe pas)
DATABASE_REPLICA_URL=

# === Redis (cache + broker Celery) ===
REDIS_URL=redis://redis:6379/0

# === JWT ===
# Idem DJANGO_SECRET_KEY : token_urlsafe(64)
JWT_SIGNING_KEY=CHANGEME

# === CORS / CSRF (frontends prod) ===
# Domaines exacts des frontends qui appellent l'API (Next.js du site membre,
# admin, etc.). Séparer par des virgules sans espace.
CORS_ALLOWED_ORIGINS=https://www.zola-ashe.com
CSRF_TRUSTED_ORIGINS=https://www.zola-ashe.com,https://api.zola-ashe.com
# Base du site membre (redirection après paiement Swinmo).
WEB_BASE_URL=https://www.zola-ashe.com

# === Stockage objet : Cloudflare R2 (compatible S3) ===
USE_S3=True
R2_ACCESS_KEY_ID=CHANGEME
R2_SECRET_ACCESS_KEY=CHANGEME
R2_BUCKET=zola-ashe
# Endpoint R2 (forme : https://<account-id>.r2.cloudflarestorage.com)
R2_ENDPOINT_URL=https://CHANGEME.r2.cloudflarestorage.com
# En prod, l'endpoint public = l'endpoint interne (pas de NAT comme MinIO).
R2_PUBLIC_ENDPOINT_URL=https://CHANGEME.r2.cloudflarestorage.com

# === Email (Brevo SMTP) ===
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
BREVO_SMTP_USER=CHANGEME
BREVO_SMTP_KEY=CHANGEME
BREVO_API_KEY=CHANGEME
DEFAULT_FROM_EMAIL=no-reply@zola-ashe.com

# === Swinmo (paiements) ===
SWINMO_WEBHOOK_SECRET=CHANGEME
SWINMO_SECRET_KEY=sk_live_CHANGEME
SWINMO_API_URL=https://www.swinmo.shop
SWINMO_RETURN_URL=https://www.zola-ashe.com/paiement/succes
SWINMO_CANCEL_URL=https://www.zola-ashe.com/paiement/annule
# Identifiants produits réels créés dans la boutique Swinmo
SWINMO_PRODUCT_INSCRIPTION=CHANGEME
SWINMO_PRODUCT_COTISATION=CHANGEME
SWINMO_PRODUCT_DON=CHANGEME
# Tarifs FCFA (XAF)
PRICE_INSCRIPTION=10000
PRICE_COTISATION=2000
DON_MIN_AMOUNT=500

# === Données de démo : JAMAIS en prod ===
SEED_DEMO=False

# === Observabilité ===
# Créer un projet Django sur sentry.io, coller le DSN ici.
SENTRY_DSN=

# ─── nginx / TLS Let's Encrypt ───
API_DOMAIN=api.zola-ashe.com
# Email contact pour Let's Encrypt (alertes d'expiration).
ACME_EMAIL=CHANGEME@zola-ashe.com

# ─── Image GHCR à déployer ───
REGISTRY=ghcr.io/edwintchakounte
# Tag : `latest` (rolling) ou un SHA court figé (recommandé en prod).
TAG=latest
GUNICORN_WORKERS=3
