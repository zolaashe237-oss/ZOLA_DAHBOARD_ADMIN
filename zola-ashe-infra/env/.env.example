# ════════════════════════════════════════════════════════════════════
#  ZOLA ASHÉ — Variables BACKEND + SERVICES (consommé par db/backend/celery)
#  Copier en .env :  cp env/.env.example env/.env
# ════════════════════════════════════════════════════════════════════

# === Django ===
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ENV=dev
DJANGO_SECRET_KEY=changez-moi
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# === PostgreSQL (utilisé par le service db ET par le backend) ===
POSTGRES_USER=zola
POSTGRES_PASSWORD=zola
POSTGRES_DB=zola
DATABASE_URL=postgres://zola:zola@db:5432/zola
# Réplica en lecture (laisser vide tant qu'il n'existe pas)
DATABASE_REPLICA_URL=

# === Redis (cache + broker Celery) ===
REDIS_URL=redis://redis:6379/0

# === JWT ===
JWT_SIGNING_KEY=changez-moi-aussi

# === CORS / CSRF (les deux frontends Next.js) ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001

# === Stockage Cloudflare R2 ===
USE_S3=False
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zola-ashe
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# === Email (Brevo) ===
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=no-reply@zola-ashe.com

# === Swinmo (paiements) — https://www.swinmo.shop/developers ===
SWINMO_WEBHOOK_SECRET=
SWINMO_SECRET_KEY=sk_live_xxx
SWINMO_API_URL=https://www.swinmo.shop
SWINMO_RETURN_URL=http://localhost:3000/paiement/succes
SWINMO_CANCEL_URL=http://localhost:3000/paiement/annule
SWINMO_PRODUCT_ANNUAL=
SWINMO_PRODUCT_COTISATION=
SWINMO_PRODUCT_BRANCHE_FEMME=
SWINMO_PRODUCT_BRANCHE_ENFANT=
PRICE_ANNUAL=25000
PRICE_COTISATION=2000
PRICE_BRANCHE_FEMME=15000
PRICE_BRANCHE_ENFANT=15000

# === Observabilité (optionnel) ===
SENTRY_DSN=

# ─── PRODUCTION uniquement (docker-compose.prod.yml) ───
ACME_EMAIL=admin@zola-ashe.com
API_DOMAIN=api.zola-ashe.com
APP_DOMAIN=app.zola-ashe.com
ADMIN_DOMAIN=admin.zola-ashe.com
REGISTRY=ghcr.io/zola-ashe
TAG=latest
GUNICORN_WORKERS=3

SEED_DEMO=True
